# Variáveis de Ambiente

# Porta da aplicação (SquareCloud usará PORT automaticamente)
PORT=3000

# Firebase - Não compartilhe públicamente
FIREBASE_PROJECT_ID=seu_project_id
FIREBASE_PRIVATE_KEY_ID=sua_key_id
FIREBASE_PRIVATE_KEY=sua_private_key
FIREBASE_CLIENT_EMAIL=seu_email
FIREBASE_CLIENT_ID=seu_client_id
FIREBASE_AUTH_URI=sua_auth_uri
FIREBASE_TOKEN_URI=seu_token_uri
FIREBASE_AUTH_PROVIDER_CERT_URL=sua_cert_url

# Nota: Copie seu arquivo firebase-key.json na pasta raiz do projeto
# Este arquivo deve estar no .gitignore por segurança
